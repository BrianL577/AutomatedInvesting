# Which broker to trade through: "ibkr" (default — free paper trading, no
# funding required), "ninjatrader" (free sim account, Windows-only desktop
# app), or "tradovate" (requires a funded live account + paid API add-on
# before Tradovate will issue API keys). See IBKR.md / NINJATRADER.md / README.md.
BROKER=ibkr

# ---------------------------------------------------------------------------
# NinjaTrader (BROKER=ninjatrader) — free sim account via the Automated
# Trading Interface (ATI). Must run on the same Windows machine as
# NinjaTrader (or a Windows VPS with it installed) — see NINJATRADER.md.
# ---------------------------------------------------------------------------
# NinjaTrader's ATI "incoming" folder (Tools > Options > Automated Trading
# Interface in NinjaTrader). Default: %USERPROFILE%\Documents\NinjaTrader 8\incoming
NT_INCOMING_DIR=
# Folder where the companion JJBotExporter NinjaScript writes bars.csv/fills.csv
# — must match that script's "Export Directory" property.
NT_EXPORT_DIR=
# Comma-separated list of sim account names to trade (e.g. multiple sim
# accounts). Leave blank to use whatever's saved on the dashboard's "My
# Accounts" page; defaults to Sim101 if neither is set.
NT_ACCOUNT_NAMES=
# Exact NinjaTrader instrument name for the current front-month contract,
# e.g. "NQ 12-26" (ATI has no contract-lookup endpoint).
NT_INSTRUMENT=
# Timezone NinjaTrader's chart timestamps are actually in (check NinjaTrader:
# Tools > General Options > Time Zone). Used by scripts/sync_bars_to_supabase.py
# to convert bar timestamps to true UTC before storing — get this wrong and
# every session boundary in the backtester silently shifts.
NT_BAR_TIMEZONE=America/Chicago

# ---------------------------------------------------------------------------
# Interactive Brokers (BROKER=ibkr) — connects to a running TWS or IB
# Gateway process, not a hosted REST API. See IBKR.md for how to run one
# headless (e.g. on Railway via a community IB Gateway + IBC Docker image).
# ---------------------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
# Comma-separated paper account IDs (start with "DU") to trade. Leave blank
# to trade every paper account returned by the login. Get these from your
# IBKR "My Accounts" page, or from your dashboard's My Accounts page once
# you've entered them there.
IBKR_ACCOUNT_NAMES=

# ---------------------------------------------------------------------------
# Tradovate (BROKER=tradovate) — DEMO ONLY. Never point this bot at a live
# account. Requires a funded live Tradovate account + the $25/mo API Access
# add-on before trader.tradovate.com will show the key-generation UI.
# ---------------------------------------------------------------------------
TRADOVATE_ENV=demo
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_DEVICE_ID=jj-bot-01

# Comma-separated list of Tradovate account names to trade (supports
# multiple accounts under one login — e.g. several TopStep evals/funded
# accounts). Leave blank to trade every active account on the login.
TRADOVATE_ACCOUNT_NAMES=

# Bot API server (jj_bot/api_server.py) — used by the dashboard's
# "Test Trade" panel and by run_live.py's HTTP status endpoint.
BOT_API_HOST=0.0.0.0
BOT_API_PORT=8787
# Comma-separated list of origins allowed to call the bot API (your Vercel
# dashboard URL). Use * only for local testing.
BOT_API_CORS_ORIGINS=*

# Supabase — lets the dashboard show trades live instead of a static file
# that only updates on redeploy. Run supabase/schema.sql once in your
# Supabase project, then set these here (on whatever host runs the Python
# bot — Railway, etc). SERVICE ROLE KEY IS SECRET: it bypasses row-level
# security, never put it in the dashboard/Vercel env or in the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Crash alert email — sent if the live worker exits on an unhandled
# exception (auth failure, WebSocket death, etc). Uses Gmail SMTP with an
# App Password (myaccount.google.com/apppasswords, requires 2FA), never a
# regular account password. Leave blank to disable (crash alerts skipped,
# logged only).
SMTP_USER=
SMTP_PASSWORD=
# Recipient address. Defaults to SMTP_USER if left blank.
ALERT_EMAIL_TO=
