# Tradovate API credentials — DEMO ONLY. Never point this bot at a live account.
TRADOVATE_ENV=demo
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_DEVICE_ID=jj-bot-01

# Comma-separated list of Tradovate account names to trade (supports
# multiple accounts under one login — e.g. several TopStep evals/funded
# accounts). Leave blank to trade every active account on the login.
TRADOVATE_ACCOUNT_NAMES=

# Bot API server (jj_bot/api_server.py) — used by the dashboard's
# "Test Trade" panel and by run_live.py's HTTP status endpoint.
BOT_API_HOST=0.0.0.0
BOT_API_PORT=8787
# Comma-separated list of origins allowed to call the bot API (your Vercel
# dashboard URL). Use * only for local testing.
BOT_API_CORS_ORIGINS=*

# Supabase — lets the dashboard show trades live instead of a static file
# that only updates on redeploy. Run supabase/schema.sql once in your
# Supabase project, then set these here (on whatever host runs the Python
# bot — Railway, etc). SERVICE ROLE KEY IS SECRET: it bypasses row-level
# security, never put it in the dashboard/Vercel env or in the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
