# Set these in Vercel Project Settings -> Environment Variables (not in this
# file — this is just a reference for local dev).
#
# Public/anon key only — this is safe to expose in the browser. It can only
# read the trades table (see supabase/schema.sql RLS policy), never write.
# Without these set, the dashboard falls back to the static
# dashboard/data/trades.json file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY (no NEXT_PUBLIC_ prefix — never expose these to the browser):

# Enables saving strategies from the Strategy Creator. The service role key
# bypasses row-level security; it is used only inside server API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Enables AI strategy generation (/api/generate-strategy) via the Claude API.
# Get a key at https://platform.claude.com/ — used only server-side.
ANTHROPIC_API_KEY=
