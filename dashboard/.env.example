# Set these in Vercel Project Settings -> Environment Variables (not in this
# file — this is just a reference for local dev).
#
# Public/anon key only — this is safe to expose in the browser. It can only
# read the trades table (see supabase/schema.sql RLS policy), never write.
# Without these set, the dashboard falls back to the static
# dashboard/data/trades.json file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY (no NEXT_PUBLIC_ prefix — never expose these to the browser):

# Enables saving strategies from the Strategy Creator. The service role key
# bypasses row-level security; it is used only inside server API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Enables AI strategy generation (/api/generate-strategy) via the Claude API.
# Get a key at https://platform.claude.com/ — used only server-side.
ANTHROPIC_API_KEY=

# Your always-on bot API host (e.g. Railway — see RAILWAY.md), no trailing
# slash. Required for /api/strategy-chat: on Vercel's Hobby plan, serverless
# functions are hard-capped at 10s regardless of any maxDuration set in the
# route code, but a Claude call with extended thinking on a conversational
# strategy question routinely takes longer than that (confirmed live via
# FUNCTION_INVOCATION_TIMEOUT). So the dashboard dispatches the actual model
# call to this host's /api/ai-job endpoint (see jj_bot/api_server.py), which
# isn't time-boxed, and polls for the result instead of waiting on it
# inline. The bot API host also needs its OWN ANTHROPIC_API_KEY set in its
# environment (e.g. Railway's env vars) — it calls Anthropic directly, not
# via this Vercel deployment's key.
BOT_API_URL=
